{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost; Database=SchoolManagementDb; Trusted_Connection=True; TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "SchoolMgmt@SuperSecretKey2024!MustBe32CharactersOrLonger!",
    "Issuer": "SchoolMgmt",
    "Audience": "SchoolMgmtApp",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
    
  "RedisSettings": {
    "ConnectionString": "localhost:6379",
    "DefaultTtlMinutes": 30
  },

  "SendGridSettings": {
    "ApiKey": "YOUR_SENDGRID_KEY",
    "FromEmail": "noreply@school.com",
    "FromName": "EduManage"
  },

  "HangfireSettings": {
    "DashboardPath": "/hangfire"
  }
}
